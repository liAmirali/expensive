generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String              @id @default(uuid())
  email                String              @unique
  passwordHash         String
  fullName             String
  avatarUrl            String?
  phoneNumber          String?
  defaultCurrency      String
  preferredLocale      String
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  isActive             Boolean             @default(true)
  emailVerified        Boolean             @default(false)
  groupMemberships     GroupMembership[]
  groupsCreated        Group[]             @relation("GroupCreatedBy")
  invitationsSent      GroupMembership[]   @relation("GroupMembershipInvitedBy")
  ledgersParticipating LedgerParticipant[]
  ledgersCreated       Ledger[]            @relation("LedgerCreatedBy")
  expensesCreated      Expense[]           @relation("ExpenseCreatedBy")
  expensesPaid         Expense[]           @relation("ExpensePaidBy")
  settlementsSent      Settlement[]        @relation("SettlementFrom")
  settlementsRecv      Settlement[]        @relation("SettlementTo")
  refreshTokens        RefreshToken[]
  expenseSplits        ExpenseSplit[]
}

model Group {
  id           String            @id @default(uuid())
  name         String
  description  String?
  baseCurrency String
  createdById  String
  createdAt    DateTime          @default(now())
  archivedAt   DateTime?
  createdBy    User              @relation("GroupCreatedBy", fields: [createdById], references: [id])
  memberships  GroupMembership[]
  ledgers      Ledger[]

  @@index([createdById])
}

model GroupMembership {
  id          String                @id @default(uuid())
  groupId     String
  userId      String
  role        GroupRole
  joinedAt    DateTime              @default(now())
  invitedById String?
  status      GroupMembershipStatus @default(PENDING)
  group       Group                 @relation(fields: [groupId], references: [id])
  user        User                  @relation(fields: [userId], references: [id])
  invitedBy   User?                 @relation("GroupMembershipInvitedBy", fields: [invitedById], references: [id])

  @@unique([groupId, userId])
  @@index([userId])
  @@index([groupId])
}

model Ledger {
  id           String              @id @default(uuid())
  groupId      String
  name         String
  description  String?
  visibility   LedgerVisibility
  currency     String
  createdById  String
  createdAt    DateTime            @default(now())
  closedAt     DateTime?
  group        Group               @relation(fields: [groupId], references: [id])
  createdBy    User                @relation("LedgerCreatedBy", fields: [createdById], references: [id])
  participants LedgerParticipant[]
  expenses     Expense[]
  settlements  Settlement[]

  @@index([groupId])
}

model LedgerParticipant {
  ledgerId String
  userId   String
  joinedAt DateTime @default(now())
  ledger   Ledger   @relation(fields: [ledgerId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@id([ledgerId, userId])
  @@index([userId])
}

model Expense {
  id          String         @id @default(uuid())
  ledgerId    String
  payerId     String
  title       String
  description String?
  totalAmount Decimal        @db.Decimal(18, 6)
  currency    String
  expenseDate DateTime
  splitMethod SplitMethod
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  isVoided    Boolean        @default(false)
  ledger      Ledger         @relation(fields: [ledgerId], references: [id])
  payer       User           @relation("ExpensePaidBy", fields: [payerId], references: [id])
  createdBy   User           @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  splits      ExpenseSplit[]
  items       Item[]

  @@index([ledgerId])
}

model ExpenseSplit {
  id         String  @id @default(uuid())
  expenseId  String
  userId     String
  amountOwed Decimal @db.Decimal(18, 6)
  expense    Expense @relation(fields: [expenseId], references: [id])
  user       User    @relation(fields: [userId], references: [id])

  @@index([expenseId])
  @@index([userId])
}

model Item {
  id        String  @id @default(uuid())
  expenseId String
  name      String
  amount    Decimal @db.Decimal(18, 6)
  quantity  Int     @default(1)
  expense   Expense @relation(fields: [expenseId], references: [id])
}

model Settlement {
  id             String   @id @default(uuid())
  ledgerId       String
  fromUserId     String
  toUserId       String
  amount         Decimal  @db.Decimal(18, 6)
  settlementDate DateTime
  note           String?
  ledger         Ledger   @relation(fields: [ledgerId], references: [id])
  fromUser       User     @relation("SettlementFrom", fields: [fromUserId], references: [id])
  toUser         User     @relation("SettlementTo", fields: [toUserId], references: [id])

  @@index([ledgerId])
  @@index([fromUserId])
  @@index([toUserId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  jti       String    @unique
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum GroupRole {
  OWNER
  ADMIN
  MEMBER
}

enum GroupMembershipStatus {
  PENDING
  ACTIVE
  REMOVED
}

enum LedgerVisibility {
  PRIVATE_TO_PARTICIPANTS
  VISIBLE_TO_GROUP
}

enum SplitMethod {
  EQUAL
  EXACT
  PERCENTAGE
  ITEMIZED
}
