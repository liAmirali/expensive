  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterBodyDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string"
          },
          "phoneNumber": {
            "type": "string"
          },
          "preferredCurrency": {
            "type": "string"
          },
          "preferredLocale": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password",
          "fullName"
        ]
      },
      "AuthTokensDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "accessToken",
          "refreshToken"
        ]
      },
      "LoginBodyDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "RefreshBodyDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "MeDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true
          },
          "phoneNumber": {
            "type": "string",
            "nullable": true
          },
          "preferredCurrency": {
            "type": "string"
          },
          "preferredLocale": {
            "type": "string"
          },
          "isActive": {
            "type": "boolean"
          },
          "emailVerified": {
            "type": "boolean"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "email",
          "fullName",
          "preferredCurrency",
          "preferredLocale",
          "isActive",
          "emailVerified",
          "createdAt",
          "updatedAt"
        ]
      },
      "UpdateMeDto": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string"
          },
          "phoneNumber": {
            "type": "string"
          },
          "preferredCurrency": {
            "type": "string"
          },
          "preferredLocale": {
            "type": "string"
          }
        }
      },
      "UserPublicDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "email",
          "fullName"
        ]
      },
      "CreateGroupDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "members": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "name"
        ]
      },
      "GroupRole": {
        "type": "string",
        "enum": [
          "OWNER",
          "ADMIN",
          "MEMBER"
        ]
      },
      "GroupMembershipStatus": {
        "type": "string",
        "enum": [
          "PENDING",
          "ACTIVE",
          "REMOVED"
        ]
      },
      "GroupMemberReducedDTO": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "role": {
            "allOf": [
              {
                "$ref": "#/components/schemas/GroupRole"
              }
            ]
          },
          "status": {
            "allOf": [
              {
                "$ref": "#/components/schemas/GroupMembershipStatus"
              }
            ]
          },
          "user": {
            "$ref": "#/components/schemas/UserPublicDTO"
          }
        },
        "required": [
          "userId",
          "role",
          "status",
          "user"
        ]
      },
      "GroupDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "createdById": {
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
